---
- name: Install Nginx on Pathnex Server
  hosts: all
  became: yes

  tasks:
   - name: Install nginx
     yum:
      name: nginx
      state: present






  provider "aws" {
  region = "us-east-1"
  }

resource "aws_instance" "Pathnex_ec2" {
 ami  = "ami-0123dnkdnc"
 instance_type = "t2.micro"


 tags: {
   name = "Pathnex_ec2"
   environment = "dev"
 }
}






apiVersion: v1
kind: Pod
metadata:
   name: Pathnex-Pod

spec:
 containers:
   name: web
   image: nginx:latest
   ports:
    - containerPort: 80  



